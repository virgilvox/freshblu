# FreshBlu DigitalOcean Deployment Configuration
# Copy to .env and fill in values before deploying.

# --- Required ---

# Your domain name (must have DNS A record pointing to this droplet)
DOMAIN=freshblu.example.com

# PostgreSQL password (generate a strong random string)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Bcrypt pepper for token hashing (generate a strong random string)
FRESHBLU_PEPPER=change-me-to-a-random-pepper

# --- Optional ---

# Allow unauthenticated device registration (default: true)
# Set to "false" to require an existing device token to register new devices
FRESHBLU_OPEN_REGISTRATION=true

# Rust log level (default: freshblu=info)
RUST_LOG=freshblu=info

# Max message payload in bytes (default: 1048576 = 1MB)
# FRESHBLU_MAX_MESSAGE_SIZE=1048576

# Path to persistent data on the DO Block Storage volume
# Default: /mnt/freshblu-data
DATA_PATH=/mnt/freshblu-data
