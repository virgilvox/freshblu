{
  "name": "freshblu",
  "version": "1.0.0",
  "description": "FreshBlu client SDK - Meshblu-compatible IoT messaging. Works in browser and Node.js.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.global.js",
  "jsdelivr": "dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "keywords": [
    "meshblu",
    "freshblu",
    "iot",
    "mqtt",
    "m2m",
    "messaging"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/virgilvox/freshblu"
  },
  "homepage": "https://github.com/virgilvox/freshblu#readme",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "msw": "^2.12.10",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "mqtt": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "mqtt": {
      "optional": true
    }
  }
}
