FROM rust:1.77-alpine AS builder

RUN apk add --no-cache musl-dev pkgconfig openssl-dev openssl-libs-static

WORKDIR /app
COPY . .

RUN cargo build --release --bin freshblu-router

FROM alpine:3.19

RUN apk add --no-cache ca-certificates

COPY --from=builder /app/target/release/freshblu-router /usr/local/bin/freshblu-router

CMD ["freshblu-router"]
