FROM rust:1-alpine AS builder

RUN apk add --no-cache musl-dev pkgconfig openssl-dev openssl-libs-static

WORKDIR /app
COPY . .

RUN cargo build --release --bin freshblu-server \
    --features "postgres,cache" \
    --no-default-features

FROM alpine:3.21

RUN apk add --no-cache ca-certificates curl

COPY --from=builder /app/target/release/freshblu-server /usr/local/bin/freshblu-server

EXPOSE 3000 1883

CMD ["freshblu-server"]
